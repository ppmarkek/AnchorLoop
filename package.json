{
  "name": "anchorloop",
  "version": "0.1.0",
  "description": "Engineer-controlled, agent-neutral workflow for AI-assisted software delivery.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppmarkek/AnchorLoop.git"
  },
  "bugs": {
    "url": "https://github.com/ppmarkek/AnchorLoop/issues"
  },
  "homepage": "https://github.com/ppmarkek/AnchorLoop#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "anchorloop": "npm/bin/anchorloop.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "npm/bin/anchorloop.js",
    "npm/scripts/version.js",
    "npm/scripts/registry-smoke.js",
    "src/anchorloop/__init__.py",
    "src/anchorloop/command.py",
    "src/anchorloop/cli.py",
    "src/anchorloop/project.py",
    "src/anchorloop/project_lock.py",
    "src/anchorloop/quality.py",
    "src/anchorloop/safe_fs.py",
    "src/anchorloop/skill_install.py",
    "src/anchorloop/transaction.py",
    "src/anchorloop/version.py",
    "src/anchorloop/skills/",
    "pyproject.toml",
    "README.md",
    "CONTEXT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "LICENSE",
    "docs/"
  ],
  "scripts": {
    "test": "npm run test:npm",
    "test:npm": "node --test npm/test/anchorloop.test.js npm/test/version.test.js",
    "version:check": "node npm/scripts/version.js",
    "prepack": "npm run version:check",
    "pack:check": "npm pack --dry-run",
    "registry:smoke": "node npm/scripts/registry-smoke.js"
  }
